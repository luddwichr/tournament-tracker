{
  "name": "devcontainer",
  "dockerFile": "Dockerfile",
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  /*
  npm ci runs as updateContentCommand (not postCreateCommand) because waitFor defaults
  to updateContentCommand: VS Code blocks connecting/activating extensions until it
  finishes. Extensions like oxc's language server spawn node_modules binaries on
  activation, so if npm ci ran later (in the background, after postCreateCommand) those
  binaries could still be mid-write, crashing the server with SIGBUS.
  */
  "updateContentCommand": "npm ci",
  /*
  Install the playwright-cli skill at user level (~/.claude/skills). This must happen
  after the claude-code-config volume is mounted (a Dockerfile RUN would be shadowed by
  the volume on rebuilds) and re-runs on every rebuild, keeping the skill in sync with
  the pinned @playwright/cli version.
  */
  "postCreateCommand": "cd ~ && playwright-cli install --skills",
  "forwardPorts": [5173, 4173],
  "customizations": {
    "vscode": {
      "extensions": [
        "vue.volar",
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "oxc.oxc-vscode",
        "ms-playwright.playwright",
        "vitest.explorer",
        "github.vscode-github-actions"
      ]
    }
  },
  "mounts": [
    /*
    Create a dedicated volume for the bash history, claude code config, and gh CLI
    auth, so that they persist across container re-builds and restarts. Without the
    gh volume, `gh auth login` has to be repeated after every rebuild (its token
    lives in ~/.config/gh/hosts.yml). The volumes are isolated per devcontainer
    instance (using the devcontainerId in the volume name).
    */
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/developer/.claude,type=volume",
    "source=gh-config-${devcontainerId},target=/home/developer/.config/gh,type=volume"
  ]
}
