{
  "name": "devcontainer",
  "dockerFile": "Dockerfile",
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  /*
  Install the playwright-cli skill at user level (~/.claude/skills). This must happen
  after the claude-code-config volume is mounted (a Dockerfile RUN would be shadowed by
  the volume on rebuilds) and re-runs on every rebuild, keeping the skill in sync with
  the pinned @playwright/cli version.
  */
  "postCreateCommand": "npm ci && cd ~ && playwright-cli install --skills",
  "forwardPorts": [5173, 4173],
  "customizations": {
    "vscode": {
      "extensions": [
        "vue.volar",
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "oxc.oxc-vscode",
        "ms-playwright.playwright",
        "vitest.explorer",
        "github.vscode-github-actions"
      ]
    }
  },
  "mounts": [
    /*
    Create a dedicated volume for the bash history and claude code config, so that they persist across container re-builds and restarts.
    The volumes are isolated per devcontainer instance (using the devcontainerId in the volume name). 
    */
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/developer/.claude,type=volume"
  ]
}
