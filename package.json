{
  "name": "worldcup-2026",
  "version": "0.1.0",
  "private": true,
  "description": "Offline-first PWA to track the FIFA World Cup 2026 results, standings and knockout bracket.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "run-p -c typecheck:vue typecheck:ts7",
    "typecheck:vue": "node scripts/vue-tsc6.js -b tsconfig.app.json tsconfig.vitest.json",
    "typecheck:ts7": "tsc -b tsconfig.node.json tsconfig.e2e.json",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:pwa": "playwright test --config playwright.pwa.config.ts",
    "lint": "oxlint --deny-warnings && eslint . --max-warnings 0",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "lint:unused": "knip",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "size": "size-limit",
    "renovate:validate": "npx --yes --ignore-scripts --package renovate@43.259.3 -- renovate-config-validator",
    "fetch:fifa-ranking": "node scripts/fetch-fifa-ranking.ts",
    "fetch:squads": "node scripts/fetch-squads.ts",
    "scan:sast": "sh .opengrep/scan.sh",
    "scan:secrets": "gitleaks git --no-banner --redact .",
    "scan:workflows": "zizmor .github/workflows",
    "scan:licenses": "trivy fs --quiet --scanners license --pkg-types library --severity UNKNOWN,MEDIUM,HIGH,CRITICAL --ignore-policy .trivy/license-exceptions.rego --exit-code 1 .",
    "scan:deps": "trivy fs --quiet --scanners vuln --pkg-types library --severity HIGH,CRITICAL --ignore-unfixed --exit-code 1 .",
    "scan:image": "trivy image --quiet --pkg-types os --severity HIGH,CRITICAL --ignore-unfixed --exit-code 1 \"$(grep -m1 '^FROM ' .devcontainer/Dockerfile | awk '{print $2}')\"",
    "scan:dockerfile": "trivy config --quiet --severity HIGH,CRITICAL --exit-code 1 .devcontainer/Dockerfile",
    "sbom": "trivy fs --quiet --format cyclonedx --scanners license --output sbom.cdx.json .",
    "check:code": "run-p -c --aggregate-output typecheck format:check lint lint:unused test:unit:coverage scan:sast scan:secrets scan:licenses scan:deps scan:dockerfile",
    "check:build": "npm run build && npm run test:e2e && npm run size && npm run test:e2e:pwa",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "flag-icons": "7.5.0",
    "pinia": "4.0.2",
    "pinia-plugin-persistedstate": "4.7.1",
    "vue": "3.5.40",
    "vue-router": "5.2.0",
    "workbox-window": "7.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@size-limit/file": "12.1.0",
    "@types/node": "26.1.1",
    "@typescript/native": "npm:typescript@7.0.2",
    "@vitejs/plugin-vue": "6.0.8",
    "@vitest/coverage-v8": "4.1.10",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.7.0",
    "eslint-import-resolver-node": "0.4.0",
    "eslint-plugin-boundaries": "7.0.2",
    "eslint-plugin-oxlint": "1.73.0",
    "eslint-plugin-sonarjs": "4.2.0",
    "eslint-plugin-vue": "10.9.2",
    "eslint-plugin-vuejs-accessibility": "2.5.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "knip": "6.27.0",
    "npm-run-all2": "9.0.2",
    "oxfmt": "0.59.0",
    "oxlint": "1.73.0",
    "sass-embedded": "1.100.0",
    "size-limit": "12.1.0",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  },
  "size-limit": [
    {
      "name": "Entry JS (loaded on every page load)",
      "path": "dist/assets/index-*.js",
      "limit": "35 KB"
    },
    {
      "name": "Entry CSS (loaded on every page load)",
      "path": "dist/assets/index-*.css",
      "limit": "12 KB"
    },
    {
      "name": "Flag CSS (subset built from styles/flags.scss; catches a re-import of the full flag-icons catalog)",
      "path": "dist/assets/TeamLabel-*.css",
      "limit": "5 KB"
    },
    {
      "name": "Total dist (whole build output; catches overall bloat regardless of hot vs. lazy path)",
      "path": "dist/**/*",
      "limit": "1 MB"
    }
  ],
  "engines": {
    "node": "24.18.0",
    "npm": "12.0.1"
  },
  "allowScripts": {
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true,
    "@parcel/watcher@2.5.6": false
  }
}
