# Reject dependency versions published less than 24h ago (supply-chain hardening).
min-release-age=1
# Block install scripts from any dependency not explicitly reviewed and
# approved via `npm install-scripts approve` (recorded in package.json's
# allowScripts field; `npm install-scripts ls` shows the current state).
# Does not affect this project's own "prepare" script.
strict-allow-scripts=true
# Refuse git and tarball-URL dependencies. This is the npm 12 default; set
# explicitly so older npm versions (default "all") behave the same.
allow-git=none
allow-remote=none
# pnpm-style isolated layout: packages live in node_modules/.store, only
# declared deps are exposed as top-level symlinks, so imports of undeclared
# ("phantom") dependencies fail fast instead of resolving by accident.
install-strategy=linked
