# Pin the registry so stray user/global npm config (e.g. a leftover proxy or mirror) cannot silently redirect this project's installs. 
# Env vars and CLI flags still take precedence for deliberate per-command overrides.
registry=https://registry.npmjs.org/
# Reject dependency versions published less than 24h ago.
min-release-age=1
# Block install scripts from any dependency not explicitly reviewed and approved via `npm install-scripts approve` 
# (recorded in package.json's allowScripts field; `npm install-scripts ls` shows the current state).
# Does not affect this project's own "prepare" script.
strict-allow-scripts=true
# Refuse git and tarball-URL dependencies.
# This is the npm 12 default; set explicitly so older npm versions (default "all") behave the same.
allow-git=none
allow-remote=none
# Refuse local directory and tarball-file dependencies too, since everything in this tree installs from the registry.
# For deliberate one-offs (e.g. testing a patched fork), override per command with --allow-directory=root/--allow-file=root.
allow-directory=none
allow-file=none
# Hard-error on conflicting transitive peer ranges instead of npm's best-guess override.
# Fires at lockfile generation (npm install, Renovate lockfile updates), not during npm ci.
# Escape hatch for a verified combo: --no-strict-peer-deps.
strict-peer-deps=true
# pnpm-style isolated layout: packages live in node_modules/.store, only declared deps are exposed as top-level symlinks.
# This way, imports of undeclared ("phantom") dependencies fail fast instead of resolving by accident.
install-strategy=linked
# No funding banners in install output.
fund=false
# `npm i` saves exact versions by default (project convention: no ^/~ ranges).
save-exact=true