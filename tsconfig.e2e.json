{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    // false to match tsconfig.vitest.json — not required here (nothing
    // references this project), and composite's stricter file-listing rules
    // would preclude narrowing "include" the way tsconfig.vitest.json does.
    "composite": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.e2e.tsbuildinfo",
    "types": ["vite/client", "node"]
  },
  // Kept Vue-free on purpose so this project is type-checked by TypeScript 7 (`tsc`), not vue-tsc; see docs/typescript-7-side-by-side.md for more.
  // Don't widen this to `src/**/*.ts`/`src/**/*.vue`.
  "include": [
    "e2e/**/*.ts",
    "playwright.pwa.config.ts",
    "src/data/**/*.ts",
    "src/types/**/*.ts",
    "src/lib/**/*.ts",
    "src/**/*.d.ts",
    "env.d.ts"
  ],
  "exclude": ["src/**/*.spec.ts"]
}
