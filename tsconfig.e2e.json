{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.e2e.tsbuildinfo",
    "types": ["vite/client", "node"]
  },
  // e2e imports only the pure-TS domain layer (src/data, src/types, src/lib) — never a .vue
  // SFC nor the Vue-entangled app layer (router/stores/main). Kept Vue-free on purpose so this
  // project is type-checked by the real TypeScript 7 (`tsc`), not vue-tsc — see
  // docs/typescript-7-side-by-side.md. Don't widen this to `src/**/*.ts`/`src/**/*.vue`.
  "include": [
    "e2e/**/*.ts",
    "playwright.pwa.config.ts",
    "src/data/**/*.ts",
    "src/types/**/*.ts",
    "src/lib/**/*.ts",
    "src/**/*.d.ts",
    "env.d.ts"
  ],
  "exclude": ["src/**/*.spec.ts"]
}
