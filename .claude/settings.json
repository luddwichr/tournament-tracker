{
  "autoMemoryEnabled": false,
  "plansDirectory": ".claude/plans",
  "worktree": {
    "baseRef": "head"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm run typecheck)",
      "Bash(npm run test:unit)",
      "Bash(npm run test:e2e)",
      "Bash(npm run lint)",
      "Bash(npm run format)",
      "Bash(npm run dev)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/hooks/statusline.js"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-code.sh",
            "timeout": 300,
            "statusMessage": "Running the full check:code gate...",
            "asyncRewake": true
          }
        ]
      }
    ]
  }
}
